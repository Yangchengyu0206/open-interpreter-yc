# ════════════════════════════════════════════════════════════════════════════════
# Open Interpreter YC — 環境設定範本
# 複製為 .env 並填入你的值
# ════════════════════════════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────────────────────────
# company = 公司內部 LLM（gpt-oss-120b，無需外網 token）
# hf      = HuggingFace Router（需填 HF_TOKEN）
LLM_PROVIDER=company

# ── 公司內部 LLM（LLM_PROVIDER=company 時生效）───────────────────────────────
LLM_API_BASE=https://llm.ai.himax.com.tw/v1
LLM_MODEL=openai/gpt-oss-120b
LLM_API_KEY=

# ── HuggingFace Router（LLM_PROVIDER=hf 時生效）──────────────────────────────
HF_TOKEN=
HF_MODEL=openai/deepseek-ai/DeepSeek-V4-Pro:novita

# ── LLM 共用參數 ──────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0
LLM_CONTEXT_WINDOW=32000
LLM_MAX_TOKENS=4096

# ── Skills ────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=
OI_IMPORT_SKILLS=true
# CUSTOM_SKILLS_DIR=/workspace/my_skills

# ── 執行安全設定 ──────────────────────────────────────────────────────────────
OI_AUTO_RUN=false
OI_SAFE_MODE=off

# ── 離線模式 ──────────────────────────────────────────────────────────────────
OI_OFFLINE=false

# ── 其他行為 ──────────────────────────────────────────────────────────────────
OI_MAX_OUTPUT=2800
OI_CONVERSATION_HISTORY=true
OI_VERBOSE=false

# ── Insecure mode (temporary workaround) ───────────────────────────────────────
# true = skip TLS certificate verification (HIGH RISK, use only in trusted intranet)
OI_INSECURE_SKIP_TLS_VERIFY=false

# Force ignore certificate chain (only when OI_INSECURE_SKIP_TLS_VERIFY=true)
PYTHONHTTPSVERIFY=0
HF_HUB_DISABLE_SSL_VERIFY=1
REQUESTS_CA_BUNDLE=
SSL_CERT_FILE=
CURL_CA_BUNDLE=

# ── 企業內網憑證 / 代理（選填）────────────────────────────────────────────────
# 若遇到 SSL: CERTIFICATE_VERIFY_FAILED，自簽憑證通常要設定這裡。
# 1) 把公司 CA 憑證放到專案 ./certs，例如 ./certs/himax-root-ca.pem
# 2) 以下路徑用「容器內路徑」：/opt/certs/...
# REQUESTS_CA_BUNDLE=/opt/certs/himax-root-ca.pem
# SSL_CERT_FILE=/opt/certs/himax-root-ca.pem
# CURL_CA_BUNDLE=/opt/certs/himax-root-ca.pem
# NO_PROXY=localhost,127.0.0.1,llm.ai.himax.com.tw,hf-tei.ai.himax.com.tw,hxstudio.himax.com.tw
